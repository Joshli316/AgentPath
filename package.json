{
  "name": "agentpath",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"esbuild src/main.ts --bundle --outfile=dist/app.js --sourcemap --watch\" \"npx @tailwindcss/cli -i styles/main.css -o dist/styles.css --watch\"",
    "build": "esbuild src/main.ts --bundle --outfile=dist/app.js --minify && npx @tailwindcss/cli -i styles/main.css -o dist/styles.css --minify",
    "deploy": "npm run build && cp index.html dist/ && cp -r content dist/ && cp -r public/* dist/ && wrangler pages deploy dist",
    "test": "npx tsx test/smoke.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.0.0"
  }
}
